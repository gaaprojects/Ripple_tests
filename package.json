{
  "name": "fx-sentinel",
  "version": "0.0.0",
  "private": true,
  "description": "Compliance-gated FX treasury agent on XRPL Testnet (SwissHacks 2026)",
  "packageManager": "pnpm@11.0.9",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "pnpm -r --filter \"./packages/*\" build && pnpm -r --filter \"./apps/*\" build",
    "dev": "concurrently -n api,bridge,web -c green,magenta,cyan \"pnpm --filter @fx/api dev\" \"pnpm --filter @fx/bridge dev\" \"pnpm --filter @fx/web dev\"",
    "dev:api": "pnpm --filter @fx/api dev",
    "dev:bridge": "pnpm --filter @fx/bridge dev",
    "dev:web": "pnpm --filter @fx/web dev",
    "dev:risk": "cd services/risk && python -m uvicorn app.main:app --reload --port 8000",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "provision": "pnpm --filter @fx/api exec tsx ../../ops/provisioning/run-all.ts"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["better-sqlite3", "esbuild"]
  }
}
