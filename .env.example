# ─────────────────────────────────────────────────────────────
# Copy to .env and fill in. NEVER commit the real .env.
# Wallet seeds and API keys must stay out of git (see .gitignore).
# ─────────────────────────────────────────────────────────────

# --- API (apps/api) ---
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/treasury
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# XRPL — Testnet by default. Switch to Devnet if using XLS-65/66 vaults.
XRPL_ENDPOINT=wss://s.altnet.rippletest.net:51233
TREASURY_WALLET_SEED=s...        # funded testnet wallet (the agent's operating account)

# Token settings. If the RLUSD testnet issuer has NOT enabled trust-line
# locking (escrow flag), self-issue a mock USD IOU and set the flag yourself.
TOKEN_ISSUER_ADDRESS=r...
TOKEN_CURRENCY=USD

# Policy thresholds (mirrored as defaults in code; env can override for demos)
POLICY_THRESHOLD_USD=10000
POLICY_COMPLIANCE_FLAG_SCORE=60

# Routing / pathfinding. Slippage buffer (bps) on the SendMax cap; enable partial
# payments to add DeliverMin + tfPartialPayment so a payment still lands if a
# path narrows. Real mode uses ripple_path_find for the cheapest cross-currency path.
ROUTE_SLIPPAGE_BPS=50
ROUTE_PARTIAL_PAYMENT=false

# XRPL Credentials (XLS-70) KYC. When enabled the receiver must hold an accepted,
# non-expired credential of CREDENTIAL_TYPE from CREDENTIAL_ISSUER_ADDRESS, or the
# payment is escalated to hardware approval. CREDENTIAL_ISSUER_SEED lets the
# treasury issue credentials (CredentialCreate) — never commit a real seed.
CREDENTIAL_KYC_ENABLED=false
CREDENTIAL_TYPE=KYC
CREDENTIAL_ISSUER_ADDRESS=r...
CREDENTIAL_ISSUER_SEED=s...
# Subject-side seed used by the credential-issuing agent's accept step on Testnet
# (CredentialAccept must be signed by the subject). Demo/testing only — leave
# empty in production where each subject accepts with their own wallet.
CREDENTIAL_SUBJECT_SEED=

# Frankfurter FX (no key required)
FRANKFURTER_BASE_URL=https://api.frankfurter.dev/v1

# OpenSanctions screening. Leave the key blank for local demo fallback.
OPENSANCTIONS_API_KEY=
OPENSANCTIONS_BASE_URL=https://api.opensanctions.org
OPENSANCTIONS_DATASET=sanctions
OPENSANCTIONS_MATCH_THRESHOLD=0.85
PUBLIC_INTEL_ENABLED=false

# Browser origins allowed to call the API. Railway can override this with the
# deployed web URL if it changes.
CORS_ORIGINS=http://localhost:5173,http://localhost:4173,https://web-production-cba3.up.railway.app
CORS_ORIGIN_REGEX=https://.*\.(up\.railway\.app|railway\.app|pages\.dev)

# --- Firefly bridge (apps/firefly-bridge, LOCAL ONLY) ---
BRIDGE_PORT=4747

# DEVICE_MODE selects the Firefly adapter:
#   simulator (default) — signs locally with FIREFLY_MOCK_PRIVATE_KEY; no hardware needed.
#   hardware            — drives a real Firefly (ESP32-C3) over USB/serial.
DEVICE_MODE=simulator

# Simulator mode: generate a keypair with `npm run keygen --workspace apps/firefly-bridge`
# and set both values.
FIREFLY_MOCK_PRIVATE_KEY=

# Hardware mode: USB/serial path to the Firefly device.
#   Linux:   /dev/ttyUSB0  or  /dev/ttyACM0
#   macOS:   /dev/tty.usbserial-XXXX
#   Windows: COM3
BRIDGE_SERIAL_PORT=

# Public key the backend uses to verify Firefly approval signatures (hex, 64 bytes,
# uncompressed secp256k1 without 0x04 prefix). Set in both simulator and hardware modes.
#   Simulator: keygen prints it.
#   Hardware:  copy publicKey from the first /sign response and paste here.
FIREFLY_PUBLIC_KEY=

# --- Web (apps/web) ---
# Vite env vars must be prefixed VITE_
VITE_API_BASE_URL=http://localhost:8000
VITE_BRIDGE_BASE_URL=http://localhost:4747
