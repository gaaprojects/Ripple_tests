# fx-sentinel configuration — SPEC §7. Copy to .env and fill. NEVER commit .env.

# --- XRPL network (Testnet) ---
XRPL_WSS_URL=wss://s.altnet.rippletest.net:51233
XRPL_EXPLORER_BASE=https://testnet.xrpl.org

# --- Assets ---
# ⚠️ VERIFY_AT_BUILD via xrpl.org MCP + Ripple RLUSD Testnet faucet. Never hardcode from memory.
RLUSD_ISSUER_ADDRESS=
RLUSD_CURRENCY_HEX=
# project-issued demo EUR
EUD_CURRENCY=EUD

# --- Account seeds (server-held). COLD_TREASURY stores ADDRESS ONLY — never its seed. ---
HOT_SEED=
EUD_ISSUER_SEED=
COMPLIANCE_ISSUER_SEED=
OPS_SEED=
COLD_TREASURY_ADDRESS=

# Demo counterparties (faucet-funded; addresses)
COUNTERPARTY_OK_ADDRESS=
COUNTERPARTY_NEW_ADDRESS=
COUNTERPARTY_SANCTIONED_ADDRESS=

# --- Device bridge (SPEC §5.2, D12) ---
DEVICE_MODE=simulator           # simulator | hardware
BRIDGE_SERIAL_PORT=COM3         # Windows COM port for the Firefly
BRIDGE_HTTP_PORT=8787

# --- Services ---
RISK_SERVICE_URL=http://127.0.0.1:8000
API_HTTP_PORT=8080

# --- AI (non-blocking; SPEC D7) ---
ANTHROPIC_API_KEY=
CONTEXT7_API_KEY=

# --- Agent / demo (SPEC §5.12) ---
AGENT_INTERVAL_S=60
DEMO_MODE=true
